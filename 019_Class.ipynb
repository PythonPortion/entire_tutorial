   "source": [
    "class SmartPhone:\n",
    "    def __init__(self, brand, price):\n",
    "        self.brand = brand\n",
    "        self.price = price\n",
    "    \n",
    "    def description(self):\n",
    "        return f\"{self.brand} phone with price {self.price}\"\n",
    "\n",
    "iphone = SmartPhone(\"Apple\", 999)\n",
    "print(iphone.description())"
   ]
  }
